generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  USER
  PRESTATAIRE
  MODERATEUR
  ADMIN
}

enum EnrollmentStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
}

enum ServiceStatus {
  ACTIVE
  INACTIVE
  DELETED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentProvider {
  MTN
  ORANGE
  WAVE
  MOOV
  CINETPAY
}

enum SubscriptionPlan {
  FREE
  PRO
  GOLD
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// ─── Auth (NextAuth compatible) ───────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  phone         String?   @unique
  passwordHash  String?
  image         String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  prestataire Prestataire?
  bookings    Booking[]    @relation("UserBookings")
  tickets     Ticket[]
  reviews     Review[]
}

// ─── Prestataire ──────────────────────────────────────────────────────────────

model Prestataire {
  id               String           @id @default(cuid())
  userId           String           @unique
  businessName     String
  slug             String           @unique
  description      String?          @db.Text
  address          String?
  city             String?
  phone            String?
  coverImage       String?
  niu              String?
  enrollmentStatus EnrollmentStatus @default(APPROVED)
  isFeatured       Boolean          @default(false)
  latitude         Float?
  longitude        Float?
  rating           Float            @default(0)
  totalReviews     Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  services       Service[]
  bookings       Booking[]            @relation("PrestatireBookings")
  subscription   Subscription?
  enrollmentDocs EnrollmentDocument[]
  reviews        Review[]

  @@index([city])
  @@index([isFeatured])
  @@index([enrollmentStatus])
}

model EnrollmentDocument {
  id            String   @id @default(cuid())
  prestataireId String
  docType       String
  url           String
  uploadedAt    DateTime @default(now())

  prestataire Prestataire @relation(fields: [prestataireId], references: [id], onDelete: Cascade)
}

// ─── Services / Catalogue ─────────────────────────────────────────────────────

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  icon     String?
  services Service[]
}

model Service {
  id            String        @id @default(cuid())
  prestataireId String
  categoryId    String?
  name          String
  description   String?       @db.Text
  duration      Int
  price         Int
  photos        String[]
  status        ServiceStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  prestataire Prestataire @relation(fields: [prestataireId], references: [id], onDelete: Cascade)
  category    Category?   @relation(fields: [categoryId], references: [id])
  bookings    Booking[]

  @@index([prestataireId])
  @@index([categoryId])
}

// ─── Bookings ─────────────────────────────────────────────────────────────────

model Booking {
  id            String        @id @default(cuid())
  userId        String
  prestataireId String
  serviceId     String
  scheduledAt   DateTime
  durationMins  Int
  status        BookingStatus @default(PENDING)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user        User        @relation("UserBookings", fields: [userId], references: [id])
  prestataire Prestataire @relation("PrestatireBookings", fields: [prestataireId], references: [id])
  service     Service     @relation(fields: [serviceId], references: [id])
  payment     Payment?
  review      Review?

  @@index([userId])
  @@index([prestataireId])
  @@index([scheduledAt])
}

// ─── Payments ─────────────────────────────────────────────────────────────────

model Payment {
  id             String          @id @default(cuid())
  bookingId      String          @unique
  amount         Int
  commission     Int
  prestataireNet Int
  commissionRate Float
  provider       PaymentProvider
  externalRef    String?         @unique
  status         PaymentStatus   @default(PENDING)
  paidAt         DateTime?
  createdAt      DateTime        @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([status])
}

// ─── Subscriptions ────────────────────────────────────────────────────────────

model Subscription {
  id            String             @id @default(cuid())
  prestataireId String             @unique
  plan          SubscriptionPlan   @default(FREE)
  status        SubscriptionStatus @default(ACTIVE)
  startDate     DateTime           @default(now())
  endDate       DateTime?
  monthlyCount  Int                @default(0)
  lastResetAt   DateTime           @default(now())
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  prestataire Prestataire           @relation(fields: [prestataireId], references: [id], onDelete: Cascade)
  payments    SubscriptionPayment[]
}

model SubscriptionPayment {
  id             String          @id @default(cuid())
  subscriptionId String
  amount         Int
  plan           SubscriptionPlan
  provider       PaymentProvider
  externalRef    String?
  paidAt         DateTime        @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id])
}

// ─── Reviews ──────────────────────────────────────────────────────────────────

model Review {
  id            String   @id @default(cuid())
  bookingId     String   @unique
  prestataireId String
  userId        String
  rating        Int
  comment       String?  @db.Text
  createdAt     DateTime @default(now())

  booking     Booking     @relation(fields: [bookingId], references: [id])
  prestataire Prestataire @relation(fields: [prestataireId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
}

// ─── Support Tickets ──────────────────────────────────────────────────────────

model Ticket {
  id         String       @id @default(cuid())
  userId     String
  subject    String
  body       String       @db.Text
  status     TicketStatus @default(OPEN)
  assignedTo String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  user     User            @relation(fields: [userId], references: [id])
  messages TicketMessage[]
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  senderId  String
  body      String   @db.Text
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

// ─── Platform Config ──────────────────────────────────────────────────────────

model PlatformConfig {
  id             String   @id @default("singleton")
  commissionRate Float    @default(0.05)
  proPlanPrice   Int      @default(5000)
  goldPlanPrice  Int      @default(15000)
  proBookingCap  Int      @default(100)
  freeBookingCap Int      @default(10)
  updatedAt      DateTime @updatedAt
}
